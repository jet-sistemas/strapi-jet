{
  "kind": "collectionType",
  "collectionName": "autores",
  "info": {
    "singularName": "autor",
    "pluralName": "autores",
    "displayName": "Autor"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "nome": {
      "type": "string",
      "minLength": 3,
      "required": true
    },
    "avatar": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "email": {
      "type": "string",
      "minLength": 5,
      "required": true,
      "unique": true
    },
    "artigos": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::artigo.artigo",
      "mappedBy": "autor"
    }
  }
}
