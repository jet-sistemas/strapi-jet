{
  "kind": "collectionType",
  "collectionName": "artigos",
  "info": {
    "singularName": "artigo",
    "pluralName": "artigos",
    "displayName": "Artigo"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "titulo": {
      "type": "string",
      "required": true
    },
    "descricao": {
      "type": "text",
      "maxLength": 80,
      "required": true
    },
    "cover": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "slug": {
      "type": "uid",
      "targetField": "titulo"
    },
    "autor": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::autor.autor",
      "inversedBy": "artigos"
    },
    "blocos": {
      "type": "dynamiczone",
      "components": [
        "compartilhado.midia",
        "compartilhado.texto-rico",
        "compartilhado.citacao",
        "compartilhado.carrosel"
      ]
    },
    "categoria": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::categoria.categoria",
      "inversedBy": "artigos"
    }
  }
}
